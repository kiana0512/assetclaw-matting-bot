# ============================================================
# AssetClaw Win3090 Skill Node
# Feishu -> LLM Proxy Brain -> Local Skills
# ============================================================

# Runtime
ASSETCLAW_ROOT=E:\assetclaw-matting-bot
APP_ENV=dev

# Gateway
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=7865
GATEWAY_BASE_URL=http://127.0.0.1:7865

# Public URL for Feishu callback
# cloudflared 启动后，把生成的 https://xxxx.trycloudflare.com 填到这里
PUBLIC_BASE_URL=https://PLEASE_REPLACE_WITH_CLOUDFLARED_URL.trycloudflare.com
FEISHU_CALLBACK_PATH=/feishu/events

# Brain Router
BRAIN_PROVIDER=llm_proxy
BRAIN_FALLBACK_PROVIDER=local_command

# LLM Proxy Brain (OpenAI-compatible)
# BASE_URL 支持两种格式，两种都能正确工作：
#   https://llm-proxy.lilithgames.com/v1
#   https://llm-proxy.lilithgames.com/v1/chat/completions
LLM_PROXY_ENABLED=true
LLM_PROXY_BASE_URL=https://llm-proxy.lilithgames.com/v1
LLM_PROXY_API_KEY=PLEASE_FILL_WITH_ATLAS_HELPER_OR_MANUALLY
LLM_PROXY_MODEL=PLEASE_FILL_MODEL_NAME
LLM_PROXY_TIMEOUT_SECONDS=60
LLM_PROXY_OPENAI_COMPATIBLE=true

# Feishu Bot
FEISHU_APP_ID=PLEASE_FILL_FEISHU_APP_ID
FEISHU_APP_SECRET=PLEASE_FILL_FEISHU_APP_SECRET
FEISHU_VERIFICATION_TOKEN=PLEASE_FILL_FEISHU_VERIFICATION_TOKEN
FEISHU_DEFAULT_NOTIFY_CHAT_ID=

# Skill Gateway
SKILL_API_ENABLED=true
SKILL_API_TOKEN=PLEASE_CHANGE_TO_RANDOM_TOKEN
ALLOW_FILE_LIST=true
ALLOW_FILE_COPY=true
ALLOW_FILE_DELETE=false
ALLOW_FILE_READ_CONTENT=false
ALLOW_SHELL_EXEC=false
MAX_LIST_ITEMS=100

# Worker (reserved for later)
WORKER_ID=win3090-worker-01
WORKER_TOKEN=PLEASE_CHANGE_TO_RANDOM_TOKEN
WORKER_POLL_INTERVAL_SECONDS=3

# Paths
DATA_DIR=E:\assetclaw-matting-bot\data
STORAGE_DIR=E:\assetclaw-matting-bot\storage
LOG_DIR=E:\assetclaw-matting-bot\logs

# Security — E drive is the controlled workspace
# DENY_PATH_PATTERNS blocks secrets and system paths regardless of ALLOWED_ROOTS
ALLOWED_ROOTS=E:\
DENY_PATH_PATTERNS=.env;.ssh;AppData;Windows;Program Files;ProgramData;$Recycle.Bin;System Volume Information

# GPU principle — GPU is reserved for ComfyUI only, never for the agent
AGENT_RUNS_ON_GPU=false
GPU_TASK_CONCURRENCY=1

# ComfyUI (reserved for later — fake mode keeps pipeline testable without GPU)
COMFYUI_FAKE_MODE=true
COMFYUI_DIR=E:\assetclaw-matting-bot\ComfyUI
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_WORKFLOW_PATH=E:\assetclaw-matting-bot\workflows\matting_api.json
COMFYUI_TIMEOUT_SECONDS=600
COMFYUI_POLL_INTERVAL_SECONDS=2

# Batch defaults
DEFAULT_BATCH_INPUT_DIR=E:\assetclaw-matting-bot\storage\batch_inputs
DEFAULT_BATCH_OUTPUT_DIR=E:\assetclaw-matting-bot\storage\batch_outputs

# ============================================================
# Other Brain Providers (optional, leave disabled unless needed)
# ============================================================

# ArkClaw Enterprise Brain
ARKCLAW_ENABLED=false
ARKCLAW_BASE_URL=
ARKCLAW_API_KEY=
ARKCLAW_BOT_ID=
ARKCLAW_WORKSPACE_ID=
ARKCLAW_TIMEOUT_SECONDS=60
ARKCLAW_MESSAGE_MODE=local_command_first

# Claude Brain (Anthropic)
CLAUDE_BRAIN_ENABLED=false
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_TIMEOUT_SECONDS=60

# OpenAI Agents Brain
OPENAI_BRAIN_ENABLED=false
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=
OPENAI_TIMEOUT_SECONDS=60
