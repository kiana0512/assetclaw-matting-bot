# Local secrets and machine-specific configuration
.env
cookie.txt
tools/p4_assistant/workspaces.local.yaml

# Runtime state. Keep only the directory markers in Git.
data/*
!data/.gitkeep
logs/*
!logs/.gitkeep
storage/*
!storage/.gitkeep

