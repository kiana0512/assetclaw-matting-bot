# ============================================================
# AssetClaw Win3090 Animation Butler
# Main event mode: Feishu long connection (WebSocket)
# No public IP, no domain, no Cloudflare Tunnel required.
# ============================================================

# Runtime paths are auto-detected from the checkout location.
# Optional overrides: ASSETCLAW_ROOT, ANIMATION_ROOT, DATA_DIR, STORAGE_DIR, LOG_DIR.
APP_ENV=dev

# Gateway (local debug only, not exposed to internet)
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=7865
GATEWAY_BASE_URL=http://127.0.0.1:7865

# ============================================================
# Feishu (Main config)
# ============================================================

# Event mode: ws = long connection (recommended, no public URL needed)
FEISHU_EVENT_MODE=ws
FEISHU_ENABLE_WEBSOCKET=true
FEISHU_ENABLE_WEBHOOK=false
FEISHU_IGNORE_EVENTS_OLDER_THAN_SECONDS=600

FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=please_replace
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Access control (optional, semicolon-separated)
FEISHU_ADMIN_OPEN_IDS=
FEISHU_ALLOWED_OPEN_IDS=
FEISHU_ALLOWED_CHAT_IDS=
FEISHU_PROGRESS_REACTION_ENABLED=true
FEISHU_PROGRESS_REACTION_EMOJI_TYPES=敲键盘;keyboard;KEYBOARD;OK;THUMBSUP

# Bot safety
BOT_ERROR_PUSH_ENABLED=true
BOT_REQUIRE_CONFIRMATION_FOR_WRITE=false
BOT_EMOTIONAL_REPLIES_ENABLED=true
# BOT_STICKER_DIR defaults to <project>\miratsu_stickers
BOT_STICKER_PROBABILITY=0.28
BOT_STICKER_COOLDOWN_SECONDS=180
BOT_STICKER_MAX_BYTES=8000000
BOT_STICKER_EXTENSIONS=.png;.gif
USER_DEFAULT_LOCATION=上海
USER_FOOD_PREFERENCES=

# ============================================================
# Brain Router
# ============================================================

BRAIN_PROVIDER=deepseek
BRAIN_FALLBACK_PROVIDER=local_command
BRAIN_MAX_TOOL_CALLS=5
BRAIN_RESULT_SUMMARY_MODE=llm
BRAIN_MEMORY_ENABLED=true
BRAIN_MEMORY_RECENT_MESSAGES=8
BRAIN_MEMORY_COMPACT_ENABLED=true
BRAIN_MEMORY_COMPACT_NOTIFY_FEISHU=true
BRAIN_MEMORY_COMPACT_AFTER_MESSAGES=20
BRAIN_MEMORY_COMPACT_KEEP_MESSAGES=8
BRAIN_MEMORY_COMPACT_MAX_CHARS=2400

# ============================================================
# DeepSeek Brain
# ============================================================

DEEPSEEK_API_KEY=sk-xxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_FORMAT=openai
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_ROUTER_MODEL=deepseek-v4-flash
DEEPSEEK_SUMMARY_MODEL=deepseek-v4-pro
DEEPSEEK_THINKING_TYPE=disabled
DEEPSEEK_REASONING_EFFORT=medium
DEEPSEEK_STREAM=false
DEEPSEEK_TIMEOUT_SECONDS=120
DEEPSEEK_MAX_RETRIES=2
DEEPSEEK_TEMPERATURE=0.1

# ============================================================
# Legacy LLM Proxy Brain (compatibility only)
# ============================================================

LLM_PROXY_ENABLED=false
LLM_PROXY_BASE_URL=https://llm-proxy.example.com
LLM_PROXY_API_KEY=
LLM_PROXY_AUTH_HEADER=authorization_bearer
LLM_PROXY_MODEL=claude-sonnet-4-6
LLM_PROXY_OPENAI_COMPATIBLE=false
LLM_PROXY_TIMEOUT_SECONDS=60

# ============================================================
# Skill Registry
# ============================================================

SKILL_API_TOKEN=please_change_me

ALLOW_FILE_LIST=true
ALLOW_FILE_COPY=true
ALLOW_FILE_MOVE=true
ALLOW_FILE_MKDIR=true
ALLOW_FILE_DELETE=false
ALLOW_FILE_READ_CONTENT=false
ALLOW_SHELL_EXEC=false
MAX_LIST_ITEMS=100

# ============================================================
# Security
# ============================================================

SHARED_MATTING_ROOT=
SHARED_MATTING_UNC_ROOT=
# ALLOWED_ROOTS defaults to the root of the drive containing this project.
# On the public C-drive machine this allows C:\ while DENY_PATH_PATTERNS blocks Windows.
DENY_PATH_PATTERNS=.env;.ssh;Windows;$Recycle.Bin;System Volume Information

# ============================================================
# ComfyUI (fake mode by default)
# ============================================================

COMFYUI_FAKE_MODE=false
# ComfyUI defaults to the sibling folder <project-parent>\ComfyUI-aki-v3.
# ImageClip pipeline assets default to the sibling folder <project-parent>\imageclip.
# Set COMFYUI_*, MATTING_PIPELINE_REPO_DIR, or COMFYUI_WORKFLOW_PATH only when needed.
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_TIMEOUT_SECONDS=600

# Cherry postprocess runs the git-managed HTML directly in headless Chrome.
CHERRY_HTML_RUNNER_ENABLED=true
# CHERRY_POSTPROCESS_HTML_PATH defaults to <project-parent>\imageclip\cherry-postprocess.html
CHERRY_BROWSER_PATH=
CHERRY_HTML_TIMEOUT_SECONDS=900

# ============================================================
# Worker
# ============================================================

WORKER_ID=win3090-worker-01
WORKER_TOKEN=please_change_me
GPU_TASK_CONCURRENCY=1
AGENT_RUNS_ON_GPU=false

# ============================================================
# Speech / Voice
# ASR recommendation for Win3090: faster-whisper large-v3-turbo.
# TTS recommendation: IndexTTS2 with a local speaker prompt audio.
# ============================================================

SPEECH_ENGINE=funasr
SPEECH_MODEL=iic/SenseVoiceSmall
# SPEECH_MODEL_DIR defaults under <project>\storage\models\asr
SPEECH_FALLBACK_MODEL=large-v3-turbo
SPEECH_DEVICE=cuda:0
SPEECH_COMPUTE_TYPE=float16
SPEECH_BEAM_SIZE=1
SPEECH_VAD_FILTER=true
SPEECH_USE_VAD=false
SPEECH_VAD_MODEL=iic/speech_fsmn_vad_zh-cn-16k-common-pytorch
# SPEECH_VAD_MODEL_DIR defaults under <project>\storage\models\asr
SPEECH_DISABLE_UPDATE=true

TTS_ENGINE=indextts
TTS_MAX_CHARS=800
VOICE_REPLY_ON_AUDIO=true
VOICE_REPLY_PROGRESS_ENABLED=true

# IndexTTS2 repo/checkpoint locations.
# Official setup currently uses the cloned index-tts repo + uv environment.
# IndexTTS paths default under <project>\storage\models.
# Override INDEXTTS_REPO_DIR, INDEXTTS_MODEL_DIR, INDEXTTS_CFG_PATH,
# INDEXTTS_PROMPT_AUDIO only when the model is stored elsewhere.
INDEXTTS_EMO_AUDIO=
INDEXTTS_EMO_ALPHA=0.6
INDEXTTS_USE_FP16=true
INDEXTTS_USE_CUDA_KERNEL=false
INDEXTTS_USE_DEEPSPEED=false

# ============================================================
# LEGACY ONLY — Disabled for company intranet deployment.
# Do not use Cloudflare Tunnel, trycloudflare, ngrok, frp,
# Tailscale, ZeroTier, reverse SSH, or any intranet tunneling
# tool in company environment.
# Leave these empty / commented out.
# ============================================================

# PUBLIC_BASE_URL=
# FEISHU_CALLBACK_PATH=/feishu/events
# CLOUDFLARED_TUNNEL_NAME=
# CLOUDFLARED_TUNNEL_HOSTNAME=
