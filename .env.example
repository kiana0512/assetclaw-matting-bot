# ============================================================
# AssetClaw Matting Bot — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# --- Feishu App ---
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_VERIFICATION_TOKEN=xxx
FEISHU_DEFAULT_NOTIFY_CHAT_ID=

# --- Public base URL (cloudflared tunnel) ---
PUBLIC_BASE_URL=https://example.trycloudflare.com

# --- Gateway ---
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=7865
GATEWAY_BASE_URL=http://127.0.0.1:7865
WORKER_TOKEN=please_change_me

# --- Storage paths ---
DATA_DIR=E:\assetclaw-matting-bot\data
STORAGE_DIR=E:\assetclaw-matting-bot\storage
LOG_DIR=E:\assetclaw-matting-bot\logs

# --- ComfyUI ---
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_WORKFLOW_PATH=E:\assetclaw-matting-bot\workflows\matting_api.json
COMFYUI_TIMEOUT_SECONDS=600
COMFYUI_POLL_INTERVAL_SECONDS=2
# true = Pillow mock, no GPU needed (safe default)
COMFYUI_FAKE_MODE=true

# --- Worker ---
WORKER_ID=win3090-worker-01
WORKER_POLL_INTERVAL_SECONDS=3

# --- Batch defaults ---
DEFAULT_BATCH_INPUT_DIR=E:\assetclaw-matting-bot\storage\batch_inputs
DEFAULT_BATCH_OUTPUT_DIR=E:\assetclaw-matting-bot\storage\batch_outputs

# =============================================================
# OpenClaw / Cloud Agent Bridge
# The real AI brain is the cloud OpenClaw API.
# This machine only runs ComfyUI and local skills.
# Agent decisions NEVER run on the local 3090 GPU.
# =============================================================

OPENCLAW_ENABLED=false
OPENCLAW_BASE_URL=https://openclaw.example.com
OPENCLAW_API_KEY=
OPENCLAW_BOT_ID=
OPENCLAW_TIMEOUT_SECONDS=60

# relay_only: all feishu text → OpenClaw
# local_command_first: try local hardcoded commands first; fallback to OpenClaw
OPENCLAW_MESSAGE_MODE=local_command_first

# =============================================================
# Skill Gateway — controlled local skill exposure for OpenClaw
# All /skills/v1 endpoints require X-Skill-Token header.
# =============================================================

SKILL_API_ENABLED=true
SKILL_API_TOKEN=please_change_me
SKILL_REQUIRE_CONFIRMATION_FOR_DANGEROUS=true

# =============================================================
# Security
# =============================================================

# Semicolon-separated list of allowed root paths for batch I/O
ALLOWED_ROOTS=E:\assetclaw-matting-bot;E:\assetclaw_workspace;E:\batch_inputs;E:\batch_outputs

# Path fragments that are always denied (case-insensitive match)
DENY_PATH_PATTERNS=.ssh;.env;AppData;Windows;Program Files

ALLOW_FILE_LIST=true
ALLOW_FILE_READ_METADATA=true
ALLOW_FILE_READ_CONTENT=false
ALLOW_FILE_DELETE=false
ALLOW_SHELL_EXEC=false

# =============================================================
# Runtime
# =============================================================

# NEVER set to true — agent inference must not run on local GPU
AGENT_RUNS_ON_GPU=false
GPU_TASK_CONCURRENCY=1
