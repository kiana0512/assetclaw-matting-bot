# ============================================================
# AssetClaw Win3090 Skill Node
# Feishu Channel + Pluggable Brain Router + Skill Gateway + ComfyUI Worker
#
# 飞书是嘴巴，Brain Router 是大脑，Skill Gateway 是神经接口，Worker 是手脚。
# 本地 3090 GPU 只运行 ComfyUI — 不跑本地大模型。
# ============================================================

# --- Runtime root ---
ASSETCLAW_ROOT=E:\assetclaw-matting-bot

# =============================================================
# Brain Router — 可插拔大脑
# 支持: local_command | llm_proxy | arkclaw | claude | openai_agents | langgraph
# 默认 llm_proxy；没填 API key 时自动 fallback 到 local_command
# =============================================================

BRAIN_PROVIDER=llm_proxy
BRAIN_FALLBACK_PROVIDER=local_command
BRAIN_MAX_TOOL_CALLS=5
BRAIN_REQUIRE_CONFIRMATION_FOR_MEDIUM_RISK=true
BRAIN_REQUIRE_CONFIRMATION_FOR_HIGH_RISK=true

# --- LLM Proxy Brain (推荐默认，使用公司 LLM Proxy Key) ---
LLM_PROXY_ENABLED=false
LLM_PROXY_BASE_URL=
LLM_PROXY_API_KEY=
LLM_PROXY_MODEL=
LLM_PROXY_TIMEOUT_SECONDS=60
LLM_PROXY_OPENAI_COMPATIBLE=true

# --- ArkClaw Enterprise Brain ---
ARKCLAW_ENABLED=false
ARKCLAW_BASE_URL=
ARKCLAW_API_KEY=
ARKCLAW_BOT_ID=
ARKCLAW_WORKSPACE_ID=
ARKCLAW_TIMEOUT_SECONDS=60
ARKCLAW_MESSAGE_MODE=local_command_first

# --- Claude Brain (Anthropic) ---
CLAUDE_BRAIN_ENABLED=false
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_TIMEOUT_SECONDS=60

# --- OpenAI Agents Brain ---
OPENAI_BRAIN_ENABLED=false
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=
OPENAI_TIMEOUT_SECONDS=60

# --- LangGraph Brain (预留) ---
LANGGRAPH_BRAIN_ENABLED=false

# =============================================================
# Feishu Bot
# =============================================================

FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_VERIFICATION_TOKEN=xxx
FEISHU_DEFAULT_NOTIFY_CHAT_ID=

# =============================================================
# Gateway
# =============================================================

PUBLIC_BASE_URL=https://example.trycloudflare.com
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=7865
GATEWAY_BASE_URL=http://127.0.0.1:7865

# =============================================================
# Worker
# =============================================================

WORKER_ID=win3090-worker-01
WORKER_TOKEN=please_change_me
WORKER_POLL_INTERVAL_SECONDS=3
# MUST remain false — GPU is reserved for ComfyUI only
AGENT_RUNS_ON_GPU=false
GPU_TASK_CONCURRENCY=1

# =============================================================
# Skill Gateway — ArkClaw / Brain 通过此接口控制本机
# =============================================================

SKILL_API_ENABLED=true
SKILL_API_TOKEN=please_change_me
SKILL_REQUIRE_CONFIRMATION_FOR_DANGEROUS=true

# =============================================================
# Storage
# =============================================================

DATA_DIR=E:\assetclaw-matting-bot\data
STORAGE_DIR=E:\assetclaw-matting-bot\storage
LOG_DIR=E:\assetclaw-matting-bot\logs

# =============================================================
# ComfyUI
# =============================================================

COMFYUI_DIR=E:\assetclaw-matting-bot\ComfyUI
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_WORKFLOW_PATH=E:\assetclaw-matting-bot\workflows\matting_api.json
COMFYUI_TIMEOUT_SECONDS=600
COMFYUI_POLL_INTERVAL_SECONDS=2
# true = Pillow mock, no GPU needed (safe default for testing pipeline)
COMFYUI_FAKE_MODE=true

# =============================================================
# Batch defaults
# =============================================================

DEFAULT_BATCH_INPUT_DIR=E:\assetclaw-matting-bot\storage\batch_inputs
DEFAULT_BATCH_OUTPUT_DIR=E:\assetclaw-matting-bot\storage\batch_outputs

# =============================================================
# Security — 用户允许整个 E 盘作为可控工作区
# 但必须用 DENY_PATH_PATTERNS 拦截敏感目录
# =============================================================

ALLOWED_ROOTS=E:
DENY_PATH_PATTERNS=.ssh;.env;AppData;Windows;Program Files;ProgramData;$Recycle.Bin;System Volume Information
ALLOW_FILE_LIST=true
ALLOW_FILE_READ_METADATA=true
ALLOW_FILE_READ_CONTENT=false
ALLOW_FILE_DELETE=false
ALLOW_SHELL_EXEC=false

# (Legacy compat — kept for backward compatibility)
OPENCLAW_ENABLED=false
OPENCLAW_BASE_URL=
OPENCLAW_API_KEY=
OPENCLAW_MESSAGE_MODE=local_command_first
